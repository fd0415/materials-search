NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# Cloudflare R2 object storage. R2 stores files; Supabase Postgres stores metadata.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_SUBTITLE_SOURCES=bbt-subtitle-sources
R2_BUCKET_PUBLIC_ASSETS=bbt-public-assets
R2_BUCKET_AUTHORIZED_VIDEO=bbt-authorized-video
R2_PUBLIC_ASSETS_BASE_URL=https://your-public-r2-domain.example.com
